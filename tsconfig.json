{
	"compilerOptions": {
		"module": "ESNext",
		"target": "ES2020",
		"outDir": "out",
		"lib": ["ES2020"],
		"sourceMap": true,
		"rootDir": "src",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"moduleResolution": "bundler",
		"paths": {
			"@/*": ["./src/*"],
			"*": ["./*"]
		},
		"incremental": true,
		"plugins": [
			{
				"name": "@effect/language-service"
			}
		]
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", ".vscode-test", "out", "src/archive"]
}
